    - target: {fileID: 5595760888200726116, guid: 4e46bcabfb041c84290b54a983c27e11, type: 3}
      propertyPath: items.Array.data[0].description
      value: "Use the resources earned during your runs to permanently enhance your
        character.\nIncrease your stats, unlock new possibilities, and prepare for
        greater challenges ahead.\nStronger builds mean faster clears \u2014 and
        access to even tougher content."
      objectReference: {fileID: 0}
    - target: {fileID: 5595760888200726116, guid: 4e46bcabfb041c84290b54a983c27e11, type: 3}
      propertyPath: items.Array.data[1].description
      value: 'Confront deadly guardians in intense one-on-one encounters.

        Learn
        their patterns, adapt your strategy, and optimize your build to overcome
        increasingly difficult trials.

        Precision, timing, and preparation
        are the keys to victory.'
      objectReference: {fileID: 0}
    - target: {fileID: 5595760888200726116, guid: 4e46bcabfb041c84290b54a983c27e11, type: 3}
      propertyPath: items.Array.data[2].description
      value: "Face relentless waves of enemies that grow stronger over time.\nClear
        fast, stay alive, and adapt your build as the pressure rises.\nThe longer
        you survive, the greater the rewards \u2014 but one mistake can end the run."
      objectReference: {fileID: 0}
    - target: {fileID: 5595760888200726116, guid: 4e46bcabfb041c84290b54a983c27e11, type: 3}
